# ── LLM 供应商 ──
# 可选: qwen (通义千问, 默认) | deepseek
LLM_PROVIDER=qwen

# ── 通义千问 (LLM_PROVIDER=qwen 时使用) ──
DASHSCOPE_API_KEY=sk-你的DashScope_API_KEY

# ── DeepSeek (LLM_PROVIDER=deepseek 时使用) ──
DEEPSEEK_API_KEY=sk-你的DeepSeek_API_KEY

# ── 数据库 ──
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的数据库密码
DB_NAME=mem_rag
